{
  "name": "@arcis/node",
  "version": "1.4.0",
  "description": "One line of code protects your Node.js app against 45+ security flaws at runtime — XSS, SQL injection, CSRF, SSRF, HPP, rate limiting, bot detection, and more. Zero dependencies. Supply chain attack scanner included.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    },
    "./sanitizers": {
      "types": "./dist/sanitizers/index.d.ts",
      "import": "./dist/sanitizers/index.mjs",
      "require": "./dist/sanitizers/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.mjs",
      "require": "./dist/middleware/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.mjs",
      "require": "./dist/validation/index.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.mjs",
      "require": "./dist/logging/index.js"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "import": "./dist/stores/index.mjs",
      "require": "./dist/stores/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.mjs",
      "require": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:unit": "vitest run tests/index.test.ts",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:conformance": "vitest run tests/conformance.test.ts",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "security",
    "express",
    "middleware",
    "xss",
    "sql-injection",
    "nosql-injection",
    "rate-limit",
    "sanitize",
    "validation",
    "csrf",
    "helmet",
    "nodejs",
    "arcis",
    "ssrf",
    "open-redirect",
    "cors",
    "prototype-pollution",
    "command-injection",
    "path-traversal",
    "security-headers",
    "input-validation",
    "web-security"
  ],
  "author": "Gagan CM",
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^10.2.0",
    "express": "^5.2.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GagancM/arcis"
  },
  "bugs": {
    "url": "https://github.com/GagancM/arcis/issues"
  },
  "homepage": "https://github.com/GagancM/arcis#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
